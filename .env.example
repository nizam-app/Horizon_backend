# Put your real vars in `.env` in this folder (backend package root — next to package.json).
PORT=3000
# Bind address. Use 0.0.0.0 in dev so http://127.0.0.1:PORT and http://<LAN-IP>:PORT both work.
# If you set HOST to a single LAN IP only, browsers using http://127.0.0.1:5173 + API http://127.0.0.1:3000 get "Failed to fetch".
# HOST=127.0.0.1
HOST=0.0.0.0
# HOST=192.168.10.251
# Extra CORS origins (comma-separated, no spaces). Add custom domains here.
# HTTPS *.netlify.app and *.vercel.app (production + previews) are allowed by default; set CORS_ALLOW_HOSTED_PREVIEWS=false to disable.
# CORS_ORIGINS=https://claims.example.com,https://staff.example.com
MONGODB_URI=mongodb://127.0.0.1:27017/horizon
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Email PDF on new claim submit (optional — if unset, claims still save; no email sent)
# CLAIM_SUBMISSION_EMAIL_TO=emon.cse.2020@gmail.com
# CLAIM_SUBMISSION_EMAIL_FROM=Horizon Claims <claims@yourcompany.com>
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user@gmail.com
# SMTP_PASS=your-app-password

# Optional: uploads directory (absolute path, or relative to this backend folder; default uploads/ here)
# UPLOAD_DIR=./uploads

# Max PDF size per upload in MB (multer)
# MAX_UPLOAD_MB=25

# Rate limits (express-rate-limit)
# MAX_CLAIM_SUBMITS_PER_IP_HOUR=120
# MAX_CLAIM_DRAFT_SAVES_PER_IP_HOUR=3000
# MAX_LOGIN_ATTEMPTS_IP=80

# horizon-user-app / horizon-admin-app: VITE_API_BASE_URL=https://your-render-api.onrender.com